;; Clojure/Clojars deploy harness for the JVM binding of tree-sitter-language-pack.
;; Mirrors the approach used in Blockether/svar: tools.build + deps-deploy publish
;; a `com.blockether/tree-sitter-language-pack` jar to Clojars.
;;
;; The Java sources live under packages/java/src/main/java (alef-generated FFM
;; bindings, --release 25 --enable-preview). The single native FFI library
;; (libts_pack_core_ffi.{dylib,so,dll}) is bundled under resources/natives/<rid>/
;; and located at runtime by NativeLib (see packages/java/.../NativeLib.java).
{:paths ["packages/java/src/main/resources"]

 ;; JSON at the FFI boundary uses charred (reflection-free, native-image-clean)
 ;; via JsonCodec — Jackson is fully gone (no databind, no annotations): the DTOs
 ;; are built through their Builders + enum fromValue, so @JsonProperty metadata
 ;; was stripped. charred brings org.clojure/clojure transitively (fine for the
 ;; Clojure host this targets); build.clj keeps clojure off the published pom.
 ;; tools.deps powers the runtime native-jar resolution in
 ;; com.blockether.tree-sitter-language-pack/resolve-native-jar — the same
 ;; resolver the clojure CLI uses, so :mvn/repos, mirrors and settings.xml are
 ;; honoured instead of a hand-rolled HTTP GET. Loaded lazily via
 ;; requiring-resolve, so it is NOT pulled into a GraalVM native image (where the
 ;; native lib is bundled/explicit and this download path never runs).
 :deps {org.jspecify/jspecify                            {:mvn/version "1.0.0"}
        com.cnuernber/charred                            {:mvn/version "1.038"}
        io.github.tree-sitter/jtreesitter                {:mvn/version "0.26.0"}
        org.clojure/tools.deps                           {:mvn/version "0.31.1629"}}

 :aliases
 {:build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.13"}
                 slipset/deps-deploy           {:mvn/version "0.2.2"}}
          :ns-default build}}}
