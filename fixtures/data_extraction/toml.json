[
	{
		"id": "data_extraction_toml_flat",
		"description": "Data extraction: TOML flat key-value pairs",
		"category": "data_extraction",
		"tags": ["data_extraction", "toml"],
		"input": {
			"source_code": "host = \"localhost\"\nport = 8080\n",
			"config": {
				"language": "toml",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "equals", "field": "data.kind", "value": "KeyValue" },
			{ "type": "count_min", "field": "data.children", "value": 2 }
		]
	},
	{
		"id": "data_extraction_toml_table",
		"description": "Data extraction: TOML table section becomes a container KeyValue node",
		"category": "data_extraction",
		"tags": ["data_extraction", "toml"],
		"input": {
			"source_code": "[server]\nhost = \"localhost\"\nport = 8080\n",
			"config": {
				"language": "toml",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "count_min", "field": "data.children", "value": 1 }
		]
	},
	{
		"id": "data_extraction_toml_array",
		"description": "Data extraction: TOML inline array emits Sequence node",
		"category": "data_extraction",
		"tags": ["data_extraction", "toml"],
		"input": {
			"source_code": "ports = [8080, 8081, 8082]\n",
			"config": {
				"language": "toml",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "count_min", "field": "data.children", "value": 1 }
		]
	}
]
