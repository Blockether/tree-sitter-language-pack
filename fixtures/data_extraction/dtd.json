[
	{
		"id": "data_extraction_dtd_element_decl",
		"description": "Data extraction: DTD element declarations as KeyValue nodes",
		"category": "data_extraction",
		"tags": ["data_extraction", "dtd"],
		"input": {
			"source_code": "<!ELEMENT server (host, port)>\n<!ELEMENT host (#PCDATA)>\n",
			"config": {
				"language": "dtd",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "equals", "field": "data.kind", "value": "KeyValue" }
		]
	}
]
