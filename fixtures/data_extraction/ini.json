[
	{
		"id": "data_extraction_ini_flat",
		"description": "Data extraction: INI flat key-value settings",
		"category": "data_extraction",
		"tags": ["data_extraction", "ini"],
		"input": {
			"source_code": "host=localhost\nport=8080\n",
			"config": {
				"language": "ini",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "equals", "field": "data.kind", "value": "KeyValue" }
		]
	},
	{
		"id": "data_extraction_ini_section",
		"description": "Data extraction: INI section becomes a container with children",
		"category": "data_extraction",
		"tags": ["data_extraction", "ini"],
		"input": {
			"source_code": "[database]\nhost=localhost\nport=5432\n",
			"config": {
				"language": "ini",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "count_min", "field": "data.children", "value": 1 }
		]
	}
]
