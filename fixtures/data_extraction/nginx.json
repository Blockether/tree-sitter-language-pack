[
	{
		"id": "data_extraction_nginx_directives",
		"description": "Data extraction: nginx config directives as KeyValue nodes",
		"category": "data_extraction",
		"tags": ["data_extraction", "nginx"],
		"input": {
			"source_code": "worker_processes 4;\nerror_log /var/log/nginx/error.log;\n",
			"config": {
				"language": "nginx",
				"data_extraction": true
			}
		},
		"assertions": [
			{ "type": "not_error" },
			{ "type": "is_true", "field": "data" },
			{ "type": "equals", "field": "data.kind", "value": "KeyValue" }
		]
	}
]
